{
  "name": "doqix-bpa-blueprint-video",
  "version": "1.0.0",
  "description": "Do.Qix BPA Implementation Blueprint - Animated Hero Video",
  "scripts": {
    "start": "remotion studio",
    "build": "remotion render BlueprintVideo out/blueprint-video.mp4",
    "build:workflow": "remotion render WorkflowDemo out/workflow-demo.mp4",
    "build:hero": "remotion render HeroWorkflow-Full out/hero-workflow.mp4",
    "build:all": "npm run build && npm run build:workflow && npm run build:hero",
    "upgrade": "remotion upgrade"
  },
  "dependencies": {
    "@remotion/cli": "4.0.420",
    "@remotion/google-fonts": "4.0.420",
    "@remotion/transitions": "4.0.420",
    "react": "^19",
    "react-dom": "^19",
    "remotion": "4.0.420"
  },
  "devDependencies": {
    "@remotion/eslint-config": "4.0.420",
    "@types/react": "^19",
    "typescript": "^5"
  }
}
